{
  "mcpServers": {
    "technitium_dns_mcp": {
      "command": "python",
      "args": [
        "-m",
        "technitium_dns_mcp.mcp_server"
      ],
      "env": {
        "MCP_TOOL_MODE": "condensed",
        "DASHBOARDTOOL": "True",
        "TECHNITIUM_DNS_TOKEN": "",
        "TECHNITIUM_DNS_URL": "http://localhost:5380",
        "USERTOOL": "True",
        "ZONESTOOL": "True"
      }
    }
  }
}
