# Technitium DNS Server URL (default is http://localhost:5380)
TECHNITIUM_DNS_URL=http://localhost:5380

# Technitium DNS API Token / SSO Token
TECHNITIUM_DNS_TOKEN=

# SSL Verification (default: True)
TECHNITIUM_DNS_SSL_VERIFY=True

# MCP transport configuration (streamable-http or stdio)
TRANSPORT=stdio
HOST=0.0.0.0
PORT=8000

# --- Tool Toggle Switches (per-domain <DOMAIN>TOOL; set False to disable) ---
# These names match the authoritative "Toggle Env Var" column in the README
# MCP tools table (condensed action-routed surface).
DASHBOARDTOOL=True
USERTOOL=True
ZONESTOOL=True
